{"nbformat":4,"nbformat_minor":0,"metadata":{"colab":{"provenance":[]},"kernelspec":{"name":"python3","display_name":"Python 3"},"language_info":{"name":"python"},"accelerator":"GPU"},"cells":[{"cell_type":"code","execution_count":null,"metadata":{"id":"zZpLNwu6-fcg"},"outputs":[],"source":["!pip install transformers torch accelerate -q"]},{"cell_type":"code","execution_count":null,"metadata":{"id":"HoN28WPh-fch"},"outputs":[],"source":["import torch\n","import time\n","from transformers import AutoTokenizer, AutoModelForCausalLM\n","\n","MODEL_NAME = \"Qwen/Qwen2.5-3B-Instruct\"\n","\n","print(\"モデルを読み込んでいます...\")\n","tokenizer = AutoTokenizer.from_pretrained(MODEL_NAME)\n","model = AutoModelForCausalLM.from_pretrained(\n","    MODEL_NAME,\n","    torch_dtype=torch.float16,\n","    device_map=\"auto\"\n",")\n","model.eval()\n","print(\"完了\")"]},{"cell_type":"code","execution_count":null,"metadata":{"id":"RJLJBlsi-fci"},"outputs":[],"source":["# ===== 設定 =====\n","SINK_SIZE    = 10\n","WINDOW_SIZE  = 512\n","LOCAL_SIZE   = 100\n","BATCH_SIZE   = 4      # VRAMが足りない場合は小さくする（2や1）\n","ENSEMBLE_N   = 1.5    # N乗融合の乗数（1.0=通常平均、大きいほど確信度重視）\n","\n","MIN_TOKENS = SINK_SIZE + WINDOW_SIZE + LOCAL_SIZE  # 622\n","print(f\"Sink: {SINK_SIZE}, Window: {WINDOW_SIZE}, Local: {LOCAL_SIZE}\")\n","print(f\"ミニバッチサイズ: {BATCH_SIZE}\")\n","print(f\"N乗融合の乗数: {ENSEMBLE_N}\")\n","print(f\"アンサンブル使用の閾値: {MIN_TOKENS} トークン以上\")\n"]},{"cell_type":"code","execution_count":null,"metadata":{"id":"RgdK_TEP-fci"},"outputs":[],"source":["import torch.nn.functional as F\n","\n","class SWEAWithCache:\n","    \"\"\"\n","    スライド窓アンサンブル法 + KVキャッシュ版\n","\n","    アルゴリズム概要:\n","      各生成ステップで、入力を以下の3領域に分割する。\n","        [SINK (先頭10)] [WINDOW (中間512)] [LOCAL (末尾100)]\n","\n","      SINK+WINDOW はトークン列が変わらない限りKVキャッシュを再利用。\n","      LOCAL のみ毎ステップ新規計算することで推論を高速化する。\n","\n","      複数のWINDOW位置でLogitsを計算し、確率のN乗を平均して融合する。\n","\n","    キャッシュの有効範囲:\n","      - 同じ (w_start, w_end) を持つ窓は、SINK+WINDOW が同一トークン列\n","      - generate() の1呼び出し内でのみ有効（呼び出しごとに clear_cache()）\n","    \"\"\"\n","\n","    def __init__(self, model, tokenizer):\n","        self.model     = model\n","        self.tokenizer = tokenizer\n","        self.kv_cache  = {}  # (w_start, w_end) -> past_key_values\n","\n","    # ------------------------------------------------------------------\n","    # 公開メソッド\n","    # ------------------------------------------------------------------\n","\n","    def predict_next_logits(self, input_ids, n=None):\n","        \"\"\"\n","        次のトークンの予測を返す。\n","\n","        Returns:\n","            tuple(Tensor, str)\n","              - Tensor: shape (1, vocab_size)\n","                  通常生成時はLogits、アンサンブル時は正規化済み確率\n","              - str: モード説明文\n","        \"\"\"\n","        _n        = n if n is not None else ENSEMBLE_N\n","        total_len = input_ids.shape[1]\n","        mid_end   = total_len - LOCAL_SIZE\n","\n","        # ---- 通常生成（短文） ----\n","        if total_len < MIN_TOKENS:\n","            with torch.no_grad():\n","                out = self.model(input_ids)\n","            return out.logits[:, -1, :], \"通常生成\"\n","\n","        # ---- N乗融合アンサンブル + KVキャッシュ ----\n","        windows   = self._build_windows(total_len)\n","        all_probs = []\n","\n","        for w_start, w_end in windows:\n","            logits = self._predict_window(input_ids, w_start, w_end, mid_end)\n","            probs  = F.softmax(logits, dim=-1)\n","            all_probs.append(probs ** _n)\n","\n","        fused = torch.cat(all_probs, dim=0).mean(dim=0, keepdim=True)\n","        fused = fused / fused.sum(dim=-1, keepdim=True)\n","        return fused, f\"アンサンブル+KVキャッシュ（窓数{len(windows)}, N={_n}）\"\n","\n","    def clear_cache(self):\n","        \"\"\"KVキャッシュを破棄する。generate()の先頭で呼ぶ。\"\"\"\n","        self.kv_cache.clear()\n","\n","    # ------------------------------------------------------------------\n","    # 内部メソッド\n","    # ------------------------------------------------------------------\n","\n","    def _build_windows(self, total_len):\n","        \"\"\"ストライド WINDOW_SIZE//2 で窓リストを構築する。\"\"\"\n","        stride  = WINDOW_SIZE // 2\n","        mid_end = total_len - LOCAL_SIZE\n","        windows = []\n","        pos = SINK_SIZE\n","        while pos + WINDOW_SIZE <= mid_end:\n","            windows.append((pos, pos + WINDOW_SIZE))\n","            pos += stride\n","        last_start = mid_end - WINDOW_SIZE\n","        last_end   = mid_end\n","        if last_start >= SINK_SIZE:\n","            if len(windows) == 0 or windows[-1] != (last_start, last_end):\n","                windows.append((last_start, last_end))\n","        return windows\n","\n","    def _predict_window(self, input_ids, w_start, w_end, mid_end):\n","        \"\"\"\n","        1窓分の推論。SINK+WINDOWのKVを再利用し、LOCALだけ毎回計算する。\n","\n","        キャッシュがない場合:\n","          1. [SINK][WINDOW] をフル計算して past_key_values を保存\n","          2. [LOCAL] を past_key_values を使って計算\n","\n","        キャッシュがある場合:\n","          1. スキップ\n","          2. [LOCAL] を保存済み past_key_values を使って計算\n","        \"\"\"\n","        window_key = (w_start, w_end)\n","\n","        if window_key not in self.kv_cache:\n","            # SINK+WINDOW をフル計算してKVを保存\n","            sink_window_ids = torch.cat([\n","                input_ids[:, :SINK_SIZE],\n","                input_ids[:, w_start:w_end]\n","            ], dim=1)\n","            with torch.no_grad():\n","                out_sw = self.model(sink_window_ids, use_cache=True)\n","            self.kv_cache[window_key] = out_sw.past_key_values\n","\n","        # LOCALだけ追加で流す（毎ステップ必要）\n","        local_ids = input_ids[:, mid_end:]\n","        with torch.no_grad():\n","            out = self.model(\n","                local_ids,\n","                past_key_values=self.kv_cache[window_key],\n","                use_cache=False  # LOCALのKVは保存不要\n","            )\n","        return out.logits[:, -1, :]\n","\n","\n","print(\"SWEAWithCache の定義完了\")\n"]},{"cell_type":"code","execution_count":null,"metadata":{"id":"K6inYZ9W-fcj"},"outputs":[],"source":["def show_top5(x, label):\n","    \"\"\"LogitsでもN乗融合後の確率でも受け取れるTop-5表示\"\"\"\n","    if x.min().item() < 0 or x.sum().item() > 1.5:\n","        probs = F.softmax(x, dim=-1)\n","    else:\n","        probs = x  # 正規化済み確率\n","    top5 = torch.topk(probs, 5)\n","    print(f\"\\n{label} Top-5予測:\")\n","    for prob, idx in zip(top5.values[0], top5.indices[0]):\n","        token = tokenizer.decode(idx)\n","        print(f\"  '{token}' : {prob.item():.4f}\")\n","\n","\n","swea = SWEAWithCache(model, tokenizer)\n","\n","\n","def generate(text, max_new_tokens=100, n=None, verbose=True):\n","    \"\"\"\n","    テキストを受け取り、SWEAWithCache で続きを生成する。\n","\n","    Args:\n","        text          : プロンプト文字列\n","        max_new_tokens: 最大生成トークン数\n","        n             : N乗融合の乗数（None でグローバル ENSEMBLE_N を使用）\n","        verbose       : 途中経過を表示するか\n","    \"\"\"\n","    # 新しい生成ごとにキャッシュをリセット\n","    swea.clear_cache()\n","\n","    input_ids = tokenizer.encode(text, return_tensors=\"pt\").to(model.device)\n","    generated = input_ids.clone()\n","\n","    if verbose:\n","        # from swea_utils import build_windows  # 窓数表示用（なければ直接計算）\n","        total = input_ids.shape[1]\n","        stride  = WINDOW_SIZE // 2\n","        mid_end = total - LOCAL_SIZE\n","        win_count = 0\n","        pos = SINK_SIZE\n","        while pos + WINDOW_SIZE <= mid_end:\n","            win_count += 1\n","            pos += stride\n","        if mid_end - WINDOW_SIZE >= SINK_SIZE:\n","            win_count += 1\n","        print(f\"入力トークン数: {total}\")\n","        print(f\"窓数: {win_count}\")\n","        print(f\"ENSEMBLE_N: {n if n is not None else ENSEMBLE_N}\")\n","        print(f\"最大生成数: {max_new_tokens} トークン\")\n","        print(\"=\"*40)\n","        print(text, end=\"\", flush=True)\n","\n","    for step in range(max_new_tokens):\n","        out, mode = swea.predict_next_logits(generated, n=n)\n","        next_token_id = out.argmax(dim=-1, keepdim=True)\n","        if next_token_id.item() == tokenizer.eos_token_id:\n","            break\n","        generated = torch.cat([generated, next_token_id], dim=1)\n","        if verbose:\n","            print(tokenizer.decode(next_token_id[0]), end=\"\", flush=True)\n","\n","    if verbose:\n","        print(f\"\\n\\n生成トークン数: {generated.shape[1] - input_ids.shape[1]}\")\n","\n","    return tokenizer.decode(\n","        generated[0, input_ids.shape[1]:],\n","        skip_special_tokens=True\n","    )\n","\n","\n","print(\"generate() の定義完了\")"]},{"cell_type":"code","execution_count":null,"metadata":{"id":"TepropJ0-fck"},"outputs":[],"source":["import time\n","\n","def benchmark(text):\n","    \"\"\"\n","    通常生成 / v7（KVキャッシュ初回・ヒット）の速度を比較する。\n","    \"\"\"\n","    input_ids = tokenizer.encode(text, return_tensors=\"pt\").to(model.device)\n","    total_len = input_ids.shape[1]\n","    print(f\"トークン数: {total_len}\")\n","\n","    # 窓数を計算\n","    stride    = WINDOW_SIZE // 2\n","    mid_end   = total_len - LOCAL_SIZE\n","    win_count = 0\n","    pos = SINK_SIZE\n","    while pos + WINDOW_SIZE <= mid_end:\n","        win_count += 1\n","        pos += stride\n","    if mid_end - WINDOW_SIZE >= SINK_SIZE:\n","        "source":["# 新しい入力テキストを設定\n","new_prompt = \"\"\"\n","\"\"\"\n","\n","# 生成を実行\n","result = generate(new_prompt, max_new_tokens=50)\n","print(f\"\\n--- 生成結果 ---\\n{result}\")"],"execution_count":null,"outputs":[]}]}
